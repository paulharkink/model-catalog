{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>paulharkink/renovate-config"],
  "regexManagers": [
    {
      "fileMatch": ["^versions\\.env$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>.+?)\\n[A-Z_]+=(?<currentValue>.+)"
      ]
    },
    {
      "description": "Track vllm-eugr base image tags in Dockerfiles",
      "fileMatch": ["(^|/)Dockerfile$"],
      "matchStrings": [
        "ARG BASE_IMAGE=(?<depName>[^:\\s]+):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker"
    }
  ]
}
